{
  "@context": {
    "@version": 1.1,
    "merge": "https://api.merge.dev/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "Candidate": "merge:Candidate",
    "Application": "merge:Application",
    "Job": "merge:Job",
    "Offer": "merge:Offer",
    "ScheduledInterview": "merge:ScheduledInterview",
    "JobInterviewStage": "merge:JobInterviewStage",
    "Scorecard": "merge:Scorecard",
    "Department": "merge:Department",
    "Office": "merge:Office",
    "Activity": "merge:Activity",
    "RemoteUser": "merge:RemoteUser",

    "id": { "@id": "dcterms:identifier", "@type": "xsd:string" },
    "remoteId": { "@id": "merge:remote_id", "@type": "xsd:string" },
    "firstName": { "@id": "schema:givenName", "@type": "xsd:string" },
    "lastName": { "@id": "schema:familyName", "@type": "xsd:string" },
    "company": { "@id": "merge:company", "@type": "xsd:string" },
    "title": { "@id": "schema:jobTitle", "@type": "xsd:string" },
    "isPrivate": { "@id": "merge:is_private", "@type": "xsd:boolean" },
    "canEmail": { "@id": "merge:can_email", "@type": "xsd:boolean" },
    "emailAddresses": { "@id": "merge:email_addresses", "@container": "@set" },
    "phoneNumbers": { "@id": "merge:phone_numbers", "@container": "@set" },
    "tags": { "@id": "merge:tags", "@container": "@set", "@type": "xsd:string" },
    "applications": { "@id": "merge:applications", "@container": "@set", "@type": "@id" },
    "candidate": { "@id": "merge:candidate", "@type": "@id" },
    "job": { "@id": "merge:job", "@type": "@id" },
    "appliedAt": { "@id": "merge:applied_at", "@type": "xsd:dateTime" },
    "rejectedAt": { "@id": "merge:rejected_at", "@type": "xsd:dateTime" },
    "source": { "@id": "merge:source", "@type": "xsd:string" },
    "currentStage": { "@id": "merge:current_stage", "@type": "@id" },
    "name": { "@id": "schema:name", "@type": "xsd:string" },
    "status": { "@id": "merge:status", "@type": "xsd:string" },
    "departments": { "@id": "merge:departments", "@container": "@set", "@type": "@id" },
    "offices": { "@id": "merge:offices", "@container": "@set", "@type": "@id" },
    "hiringManagers": { "@id": "merge:hiring_managers", "@container": "@set", "@type": "@id" },
    "recruiters": { "@id": "merge:recruiters", "@container": "@set", "@type": "@id" },
    "overallRecommendation": { "@id": "merge:overall_recommendation", "@type": "xsd:string" },
    "activityType": { "@id": "merge:activity_type", "@type": "xsd:string" },
    "subject": { "@id": "merge:subject", "@type": "xsd:string" },
    "body": { "@id": "merge:body", "@type": "xsd:string" },
    "email": { "@id": "schema:email", "@type": "xsd:string" },
    "accessRole": { "@id": "merge:access_role", "@type": "xsd:string" },
    "createdAt": { "@id": "schema:dateCreated", "@type": "xsd:dateTime" },
    "modifiedAt": { "@id": "schema:dateModified", "@type": "xsd:dateTime" },
    "remoteWasDeleted": { "@id": "merge:remote_was_deleted", "@type": "xsd:boolean" }
  }
}
