{
  "@context": {
    "@version": 1.1,
    "merge": "https://api.merge.dev/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "Ticket": "merge:Ticket",
    "Comment": "merge:Comment",
    "Project": "merge:Project",
    "Attachment": "merge:Attachment",

    "id": { "@id": "dcterms:identifier", "@type": "xsd:string" },
    "name": { "@id": "schema:name", "@type": "xsd:string" },
    "description": { "@id": "schema:description", "@type": "xsd:string" },
    "assignees": { "@id": "merge:assignees", "@container": "@set", "@type": "@id" },
    "creator": { "@id": "merge:creator", "@type": "@id" },
    "dueDate": { "@id": "merge:due_date", "@type": "xsd:dateTime" },
    "status": { "@id": "merge:status", "@type": "xsd:string" },
    "priority": { "@id": "merge:priority", "@type": "xsd:string" },
    "ticketType": { "@id": "merge:ticket_type", "@type": "xsd:string" },
    "tags": { "@id": "merge:tags", "@container": "@set", "@type": "xsd:string" },
    "completedAt": { "@id": "merge:completed_at", "@type": "xsd:dateTime" },
    "ticketUrl": { "@id": "schema:url", "@type": "@id" },
    "body": { "@id": "merge:body", "@type": "xsd:string" },
    "isPrivate": { "@id": "merge:is_private", "@type": "xsd:boolean" },
    "fileName": { "@id": "merge:file_name", "@type": "xsd:string" },
    "fileUrl": { "@id": "merge:file_url", "@type": "@id" },
    "contentType": { "@id": "merge:content_type", "@type": "xsd:string" },
    "createdAt": { "@id": "schema:dateCreated", "@type": "xsd:dateTime" },
    "modifiedAt": { "@id": "schema:dateModified", "@type": "xsd:dateTime" },
    "remoteWasDeleted": { "@id": "merge:remote_was_deleted", "@type": "xsd:boolean" }
  }
}
