{
  "@context": {
    "@version": 1.1,
    "merge": "https://api.merge.dev/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "File": "merge:File",
    "Folder": "merge:Folder",
    "Drive": "merge:Drive",
    "FSGroup": "merge:FSGroup",
    "FSUser": "merge:FSUser",

    "id": { "@id": "dcterms:identifier", "@type": "xsd:string" },
    "name": { "@id": "schema:name", "@type": "xsd:string" },
    "description": { "@id": "schema:description", "@type": "xsd:string" },
    "fileUrl": { "@id": "schema:contentUrl", "@type": "@id" },
    "fileThumbnailUrl": { "@id": "schema:thumbnailUrl", "@type": "@id" },
    "size": { "@id": "schema:contentSize", "@type": "xsd:integer" },
    "mimeType": { "@id": "schema:encodingFormat", "@type": "xsd:string" },
    "folder": { "@id": "merge:folder", "@type": "@id" },
    "drive": { "@id": "merge:drive", "@type": "@id" },
    "folderUrl": { "@id": "schema:url", "@type": "@id" },
    "parentFolder": { "@id": "merge:parent_folder", "@type": "@id" },
    "emailAddress": { "@id": "schema:email", "@type": "xsd:string" },
    "isMe": { "@id": "merge:is_me", "@type": "xsd:boolean" },
    "users": { "@id": "merge:users", "@container": "@set", "@type": "@id" },
    "createdAt": { "@id": "schema:dateCreated", "@type": "xsd:dateTime" },
    "modifiedAt": { "@id": "schema:dateModified", "@type": "xsd:dateTime" },
    "remoteWasDeleted": { "@id": "merge:remote_was_deleted", "@type": "xsd:boolean" }
  }
}
