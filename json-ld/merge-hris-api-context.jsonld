{
  "@context": {
    "@version": 1.1,
    "merge": "https://api.merge.dev/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "Employee": "merge:Employee",
    "Company": "merge:Company",
    "Employment": "merge:Employment",
    "Team": "merge:Team",
    "Location": "merge:Location",
    "Benefit": "merge:Benefit",
    "TimeOff": "merge:TimeOff",
    "TimeOffBalance": "merge:TimeOffBalance",
    "PayGroup": "merge:PayGroup",
    "Group": "merge:Group",
    "BankInfo": "merge:BankInfo",
    "EmployeePayrollRun": "merge:EmployeePayrollRun",
    "PayrollRun": "merge:PayrollRun",

    "id": { "@id": "dcterms:identifier", "@type": "xsd:string" },
    "remoteId": { "@id": "merge:remote_id", "@type": "xsd:string" },
    "employeeNumber": { "@id": "merge:employee_number", "@type": "xsd:string" },
    "firstName": { "@id": "schema:givenName", "@type": "xsd:string" },
    "lastName": { "@id": "schema:familyName", "@type": "xsd:string" },
    "displayFullName": { "@id": "schema:name", "@type": "xsd:string" },
    "workEmail": { "@id": "schema:email", "@type": "xsd:string" },
    "personalEmail": { "@id": "merge:personal_email", "@type": "xsd:string" },
    "mobilePhoneNumber": { "@id": "schema:telephone", "@type": "xsd:string" },
    "dateOfBirth": { "@id": "schema:birthDate", "@type": "xsd:date" },
    "startDate": { "@id": "merge:start_date", "@type": "xsd:dateTime" },
    "terminationDate": { "@id": "merge:termination_date", "@type": "xsd:dateTime" },
    "employmentStatus": { "@id": "merge:employment_status", "@type": "xsd:string" },
    "manager": { "@id": "merge:manager", "@type": "@id" },
    "company": { "@id": "merge:company", "@type": "@id" },
    "team": { "@id": "merge:team", "@type": "@id" },
    "payGroup": { "@id": "merge:pay_group", "@type": "@id" },
    "groups": { "@id": "merge:groups", "@container": "@set", "@type": "@id" },
    "remoteWasDeleted": { "@id": "merge:remote_was_deleted", "@type": "xsd:boolean" },
    "createdAt": { "@id": "schema:dateCreated", "@type": "xsd:dateTime" },
    "modifiedAt": { "@id": "schema:dateModified", "@type": "xsd:dateTime" },
    "legalName": { "@id": "schema:legalName", "@type": "xsd:string" },
    "jobTitle": { "@id": "schema:jobTitle", "@type": "xsd:string" },
    "payRate": { "@id": "merge:pay_rate", "@type": "xsd:decimal" },
    "payPeriod": { "@id": "merge:pay_period", "@type": "xsd:string" },
    "payCurrency": { "@id": "merge:pay_currency", "@type": "xsd:string" },
    "employmentType": { "@id": "merge:employment_type", "@type": "xsd:string" },
    "name": { "@id": "schema:name", "@type": "xsd:string" },
    "city": { "@id": "schema:addressLocality", "@type": "xsd:string" },
    "state": { "@id": "schema:addressRegion", "@type": "xsd:string" },
    "zipCode": { "@id": "schema:postalCode", "@type": "xsd:string" },
    "country": { "@id": "schema:addressCountry", "@type": "xsd:string" },
    "providerName": { "@id": "merge:provider_name", "@type": "xsd:string" },
    "benefitPlanType": { "@id": "merge:benefit_plan_type", "@type": "xsd:string" },
    "employeeContribution": { "@id": "merge:employee_contribution", "@type": "xsd:decimal" },
    "companyContribution": { "@id": "merge:company_contribution", "@type": "xsd:decimal" },
    "balance": { "@id": "merge:balance", "@type": "xsd:decimal" },
    "grossPay": { "@id": "merge:gross_pay", "@type": "xsd:decimal" },
    "netPay": { "@id": "merge:net_pay", "@type": "xsd:decimal" }
  }
}
