      "type": "string"
    },
    "categories": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/CategoriesEnum"
      }
    },
    "image": {
      "type": "string"
    },
    "square_image": {
      "type": "string"
    },
    "color": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "passthrough_available": {
      "type": "boolean"
    },
    "available_model_operations": {
      "type": "array",
