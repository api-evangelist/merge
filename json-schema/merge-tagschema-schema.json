{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/TagSchema",
  "title": "TagSchema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique tag identifier"
    },
    "object": {
      "type": "string",
      "enum": [
        "tag"
      ]
    },
    "tag_key": {
      "type": "string",
      "description": "Tag key"
    },
    "tag_value": {
      "type": "string",
      "description": "Tag value"
    },
    "org_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "Organization ID, null for global tags"
    },
    "is_global": {
      "type": "boolean",
      "default": false,
      "description": "Whether this is a global tag"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "tag_key",
    "tag_value"
  ],
  "description": "A tag available through the gateway."
}