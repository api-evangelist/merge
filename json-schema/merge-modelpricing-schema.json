{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ModelPricing",
  "title": "ModelPricing",
  "type": "object",
  "properties": {
    "currency": {
      "type": "string",
      "enum": [
        "USD"
      ]
    },
    "input_per_million": {
      "type": "number",
      "format": "double"
    },
    "output_per_million": {
      "type": "number",
      "format": "double"
    }
  },
  "required": [
    "input_per_million",
    "output_per_million"
  ],
  "description": "Pricing information for a model."
}